// Armoire Bespoke — data model.
// Database: Neon (PostgreSQL). DATABASE_URL is the pooled connection string
// (runtime); DIRECT_URL is the direct/non-pooled string (used by prisma db push
// / migrations). Both are set in .env (local) and in Vercel's env settings.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Key/value store for global site content (logo, slogan, hero video, brand name...).
model SiteSetting {
  key   String @id
  value String
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
}

model Category {
  id                String             @id @default(cuid())
  slug              String             @unique
  name              String
  order             Int                @default(0)
  active            Boolean            @default(true)
  tagline           String?
  description       String?
  bannerType        String             @default("image") // image | video
  bannerUrl         String?
  posterUrl         String?
  sizeChartUrl      String?            // shown on Ready-Made product pages
  products          Product[]
  measurementFields MeasurementField[]
  createdAt         DateTime           @default(now())
}

model Product {
  id             String                 @id @default(cuid())
  slug           String                 @unique
  name           String
  categoryId     String
  category       Category               @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  type           String                 @default("CUSTOM") // CUSTOM (Tailor Made) | READYMADE (Ready Made)
  priceTk        Int                    @default(0)
  tailoringCharge Int                   @default(0) // Tailor Made only
  description    String?
  specs          String? // JSON string: [{label,value}]
  fabric         String?
  colors         String? // JSON string of colour names (Ready Made)
  sizeOptions    String? // JSON string: [{label,stock}] (Ready Made sizes)
  outOfStock     Boolean                @default(false)
  order          Int                    @default(0)
  active         Boolean                @default(true)
  featured       Boolean                @default(false)
  sizeChartUrl   String?
  images         ProductImage[]
  customizations ProductCustomization[]
  orderItems     OrderItem[]
  createdAt      DateTime               @default(now())
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  order     Int     @default(0)
  featured  Boolean @default(false)
}

/// A configurable dimension of a bespoke garment (lapel, collar, cuff, pocket, vent, fabric).
model CustomizationGroup {
  id           String                 @id @default(cuid())
  kind         String                 @unique // lapel | collar | cuff | pocket | vent | fabric
  name         String
  referenceUrl String?
  order        Int                    @default(0)
  choices      CustomizationChoice[]
  products     ProductCustomization[]
}

model CustomizationChoice {
  id      String             @id @default(cuid())
  groupId String
  group   CustomizationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  label   String
  order   Int                @default(0)
}

/// Which customization groups apply to a given product (bespoke options shown on its page).
model ProductCustomization {
  id        String             @id @default(cuid())
  productId String
  groupId   String
  order     Int                @default(0)
  product   Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  group     CustomizationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([productId, groupId])
}

model MeasurementField {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  label      String
  unit       String   @default("in")
  hint       String?
  order      Int      @default(0)
}

model Quote {
  id          String  @id @default(cuid())
  slot        String  @unique // manifesto | after-storytelling | after-blazer ...
  text        String
  attribution String?
  order       Int     @default(0)
}

model Section {
  key      String  @id // storytelling | lookbook | fabric | hero | craft
  title    String?
  subtitle String?
  body     String?
  config   String? // JSON
  order    Int     @default(0)
}

model Media {
  id        String   @id @default(cuid())
  url       String
  type      String   @default("image")
  alt       String?
  createdAt DateTime @default(now())
}

model Order {
  id           String      @id @default(cuid())
  publicId     String      @unique
  customerName String
  email        String
  phone        String
  address      String?
  city         String?
  appointment  String? // Home Visit | Office Appointment | Virtual Consultation
  note         String?
  subtotalTk   Int         @default(0)
  status       String      @default("PENDING") // PENDING | CONFIRMED | CANCELLED
  items        OrderItem[]
  createdAt    DateTime    @default(now())
}

/// Contact / appointment enquiries submitted from the site (admin follow-up).
model Enquiry {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String?
  subject     String?
  message     String?
  type        String   @default("contact") // contact | appointment
  appointment String? // Home Visit | Office Appointment | Virtual Consultation
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
}

/// Web Push subscriptions for admin browser notifications (new orders / enquiries).
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String?
  product      Product? @relation(fields: [productId], references: [id])
  productName  String
  type         String
  priceTk      Int      @default(0)
  qty          Int      @default(1)
  selections   String? // JSON string of chosen customizations
  measurements String? // JSON string of measurements
}
