# Copy to .env and fill in.

# Database: Neon (PostgreSQL).
# DATABASE_URL = POOLED connection string (host contains "-pooler"), used at runtime.
# DIRECT_URL   = DIRECT connection string (no "-pooler"), used by prisma db push/migrate.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/armoire?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/armoire?sslmode=require"

# Object storage: Cloudflare R2 (S3-compatible). Blank = local public/uploads fallback (dev).
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="armoire-media"
R2_PUBLIC_URL=""   # https://pub-xxxx.r2.dev or a custom domain

# Admin login (seeded on `npm run db:seed`)
ADMIN_EMAIL="admin@armoirebespoke.com"
ADMIN_PASSWORD="change-me"

# Session signing secret — use a long random string in production
AUTH_SECRET="change-me-to-a-long-random-string"

# Gmail SMTP for order-confirmation emails.
# Leave SMTP_USER / SMTP_PASS blank to run in PREVIEW mode (emails logged, not sent).
# Gmail requires a 16-char App Password (with 2FA enabled).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Armoire Bespoke <no-reply@armoirebespoke.com>"
OWNER_EMAIL="owner@example.com"

NEXT_PUBLIC_SITE_URL="http://localhost:3000"
